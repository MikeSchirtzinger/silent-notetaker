# Cloudflare Pages / Netlify response headers.
# GENERATED by `xtask gen-headers` — do not edit by hand.
# Re-generate with: cargo xtask gen-headers --out _headers
# Check freshness: cargo xtask gen-headers --out _headers --check
#
# Cross-origin isolation → crossOriginIsolated → SharedArrayBuffer →
# multithreaded WASM.
#
# COEP=credentialless (not require-corp): require-corp breaks HF CDN
# redirects (decision log 2026-06-04).
#
# CSP is REPORT-ONLY (not enforced) until Phase 6 (Extension SDK).
# ws://localhost:8765 (Claude bridge) is KEPT in hosted builds —
# decision log 2026-06-04: localhost is inside the user's trust boundary.
/*
Cross-Origin-Opener-Policy: same-origin
Cross-Origin-Embedder-Policy: credentialless
Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://cdn.jsdelivr.net https://unpkg.com https://cdn.pyke.io; worker-src 'self' blob:; connect-src 'self' blob: data: https://cdn.jsdelivr.net https://unpkg.com https://cdn.pyke.io https://huggingface.co https://*.hf.co https://cdn-lfs.huggingface.co https://cdn-lfs-us-1.huggingface.co ws://localhost:8765; img-src 'self' data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'
