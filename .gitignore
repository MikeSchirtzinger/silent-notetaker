# macOS
.DS_Store

# Rust build output
/server/target/
target/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editor
.vscode/
.idea/
*.swp

# Claude Code session state
.claude/

# wrangler local dev state (`wrangler pages dev`)
.wrangler/

# Backups / scratch
*.bak
*.log
/tmp/

# Local bridge auth token (never commit)
token
.config/

# Cloudflare Pages deploy bundle (assembled by deploy-cloudflare.sh)
/dist/

# Generated wasm sha256 manifest. scripts/build-wasm.sh writes it at the repo
# root so start.sh's root-served app can verify itself in-app (Settings → About);
# the deploy writes its own copy into dist/. Regenerated from source — never
# committed (a stale committed copy would falsely claim VERIFIED).
/wasm-hashes.txt

# Locally downloaded chromedriver binaries (browser-wasm-tests.sh caches these here)
/vendor/chromedriver/

# Vendored runtimes (R6 / K2). scripts/vendor-transformers.sh +
# scripts/vendor-ort-web.sh fetch + sha256-verify these; the binaries are NEVER
# committed (they are pinned by hash in the scripts). Vendoring is currently
# dormant infra — the live code path loads ort-web from cdn.pyke.io and
# deploy-cloudflare.sh does not ship vendor/ — but a stale committed copy would
# still defeat the hash-pinning guarantee, so keep these ignored.
/vendor/transformers-runtime/
/vendor/ort-web-*/

# Presenter notes — on-stage cheat card, not for the public repo
DEMO.md

# Orchestrator planning specs — internal, not part of the app
specs/
nemotron-asr/reference/parakeet_ref_source.txt

# A/B test harness (dev/ab-test): scripts + transcripts + scores are committed;
# the multi-MB WAV fixtures and local model symlinks are not.
/dev/ab-test/*.wav
/dev/ab-test/models-int8dec/
