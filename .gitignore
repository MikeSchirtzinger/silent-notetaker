# macOS
.DS_Store

# Rust build output
/server/target/
target/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editor
.vscode/
.idea/
*.swp

# Backups / scratch
*.bak
*.log
/tmp/

# Local bridge auth token (never commit)
token
.config/

# Cloudflare Pages deploy bundle (assembled by deploy-cloudflare.sh)
/dist/

# Generated wasm sha256 manifest. scripts/build-wasm.sh writes it at the repo
# root so start.sh's root-served app can verify itself in-app (Settings → About);
# the deploy writes its own copy into dist/. Regenerated from source — never
# committed (a stale committed copy would falsely claim VERIFIED).
/wasm-hashes.txt

# Locally downloaded chromedriver binaries (browser-wasm-tests.sh caches these here)
/vendor/chromedriver/

# Build-at-deploy vendored runtimes (R6 / K2). scripts/vendor-transformers.sh +
# scripts/vendor-ort-web.sh fetch + sha256-verify these at deploy time; the
# binaries are NEVER committed (they are pinned by hash in the scripts, copied
# into dist/vendor/ by deploy-cloudflare.sh). A stale committed copy would defeat
# the hash-pinning guarantee.
/vendor/transformers-runtime/
/vendor/ort-web-*/

# Presenter notes — on-stage cheat card, not for the public repo
DEMO.md

# Orchestrator planning specs — internal, not part of the app
specs/
nemotron-asr/reference/parakeet_ref_source.txt
